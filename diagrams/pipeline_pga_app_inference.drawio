<mxfile host="65bd71144e">
    <diagram name="4. Inference Pipeline" id="inferencepipeline">
        <mxGraphModel dx="1042" dy="124" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="860" pageHeight="820" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>

                <!-- ===== INPUTS (side by side) ===== -->
                <mxCell id="xray" value="&lt;b&gt;Ảnh X-quang&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="160" y="20" width="200" height="48" as="geometry"/>
                </mxCell>
                <mxCell id="bbox_in" value="&lt;b&gt;Bounding Box&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Người dùng vẽ vùng nghi ngờ&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="480" y="20" width="200" height="48" as="geometry"/>
                </mxCell>

                <!-- ===== GATEKEEPER ===== -->
                <mxCell id="gate" value="&lt;b&gt;EfficientNet_B3&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Gatekeeper — phân loại tổn thương xương&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="280" y="108" width="280" height="65" as="geometry"/>
                </mxCell>

                <!-- ===== DECISION ===== -->
                <mxCell id="dec" value="Âm tính hay&lt;br&gt;Dương tính?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="305" y="210" width="230" height="90" as="geometry"/>
                </mxCell>

                <!-- ===== NEGATIVE branch ===== -->
                <mxCell id="stop" value="&lt;b&gt;Kết thúc&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Ảnh bình thường — không phân đoạn&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="620" y="227" width="190" height="55" as="geometry"/>
                </mxCell>

                <!-- ===== POSITIVE branch ===== -->
                <mxCell id="prompt0" value="&lt;b&gt;Sinh Prompt Heatmap&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Bounding Box → Gaussian Heatmap (plateau, k=31)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="270" y="342" width="300" height="60" as="geometry"/>
                </mxCell>

                <!-- ===== PGA-UNet ===== -->
                <mxCell id="pga" value="&lt;b&gt;PGA-UNet — Phân đoạn tự động&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Prompt Spatial Gate + Conditioned Attention Decoder&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="260" y="445" width="320" height="65" as="geometry"/>
                </mxCell>

                <!-- ===== OUTPUT ===== -->
                <mxCell id="out" value="&lt;b&gt;Output: Mặt nạ phân đoạn&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Binary Mask — hiển thị trên Gradio UI&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="270" y="555" width="300" height="60" as="geometry"/>
                </mxCell>

                <!-- ===== ARROWS ===== -->
                <!-- Ảnh → Gatekeeper -->
                <mxCell id="a1" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" parent="1" source="xray" target="gate" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- BBox → Gatekeeper (nét đứt, không ảnh hưởng kết quả phân loại) -->
                <mxCell id="a_bbox_gate" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;dashed=1;strokeColor=#b85450;" parent="1" source="bbox_in" target="gate" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Gatekeeper → Decision -->
                <mxCell id="a2" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" parent="1" source="gate" target="dec" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Decision → Stop (âm tính) -->
                <mxCell id="a3" value="Âm tính" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" parent="1" source="dec" target="stop" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Decision → Prompt (dương tính) -->
                <mxCell id="a4" value="Dương tính" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;fontSize=11;" parent="1" source="dec" target="prompt0" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- BBox → Prompt (nét đứt, BBox được dùng để sinh heatmap) -->
                <mxCell id="a_bbox_prompt" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;dashed=1;strokeColor=#b85450;" parent="1" source="bbox_in" target="prompt0" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="580" y="255"/>
                            <mxPoint x="580" y="372"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <!-- Prompt → PGA-UNet -->
                <mxCell id="a5" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" parent="1" source="prompt0" target="pga" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- PGA-UNet → Output -->
                <mxCell id="a6" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" parent="1" source="pga" target="out" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

            </root>
        </mxGraphModel>
    </diagram>
