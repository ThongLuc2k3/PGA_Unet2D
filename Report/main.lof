\addvspace {10\p@ }
\addvspace {10\p@ }
\contentsline {figure}{\numberline {2.1}{\ignorespaces Kiến trúc SAM-Med2D với chiến lược huấn luyện kết hợp: Mô hình Generalist (SAM-Med2D nhận câu nhắc vị trí qua Prompt Encoder, tham số đóng băng {\color {cyan}$\bullet $} và học được {\color {orange}$\bullet $}) phối hợp với Mô hình Specialist (Swin-UNet tăng cường nhận thức biên), tối ưu qua hàm mất mát tổng hợp có trọng số tin cậy $\beta (U)$}}{15}{figure.2.1}%
\contentsline {figure}{\numberline {2.2}{\ignorespaces Kiến trúc mạng U-Net với 4 cấp độ phân giải: nhánh mã hóa (trái) giảm mẫu dần qua Max Pooling; nhánh giải mã (phải) khôi phục độ phân giải qua UpConv; các kết nối tắt nối đặc trưng cùng cấp từ encoder sang decoder để bù thông tin vị trí không gian bị mất}}{17}{figure.2.2}%
\contentsline {figure}{\numberline {2.3}{\ignorespaces Kiến trúc Attention U-Net: các Cổng chú ý (Attention Gates) được chèn tại các kết nối tắt, sử dụng tín hiệu gating $\mathbf {g}$ từ bộ giải mã để lọc bỏ nhiễu nền trước khi truyền đặc trưng sang tầng giải mã tương ứng}}{19}{figure.2.3}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {3.1}{\ignorespaces Kiến trúc tổng thể hệ thống hỗ trợ chẩn đoán: bốn giai đoạn liên hoàn từ tiền xử lý ảnh, sàng lọc bệnh lý (MobileNetV4), phân đoạn có hướng dẫn (PGA-UNet), đến thẩm định an toàn và tinh chỉnh câu nhắc tự động (IPR + GradCAM)}}{31}{figure.3.1}%
\contentsline {figure}{\numberline {3.2}{\ignorespaces Quy trình tiền xử lý dữ liệu: chuyển JPEG → PNG (xóa ICC Profile), upload và gán nhãn bounding box thủ công trên Roboflow (2000/3746 ảnh), huấn luyện YOLOv11s, phát hiện vùng nhiễu R/L trên toàn bộ tập, xóa nhiễu bằng inpainting, chuẩn hóa thang xám và resize 512×512}}{34}{figure.3.2}%
\contentsline {figure}{\numberline {3.3}{\ignorespaces Minh họa kết quả xóa nhiễu: (a) Ảnh X-quang thô chứa ký tự R/L, (b) Bounding Box phát hiện bởi YOLOv11s, (c) Ảnh sau khi xóa nhiễu}}{36}{figure.3.3}%
\contentsline {figure}{\numberline {3.4}{\ignorespaces Minh họa tăng cường dữ liệu đồng bộ: (a) Bộ ba gốc [Ảnh, Mặt nạ, Câu nhắc], (b) Sau lật ngang, (c) Sau xoay $+12^{\circ }$ --- ba thành phần luôn biến đổi đồng nhất}}{38}{figure.3.4}%
\contentsline {figure}{\numberline {3.5}{\ignorespaces Kiến trúc PGA-UNet (Prompt-Guided Attention U-Net): Cổng không gian (Prompt Spatial Gate) tích hợp bản đồ nhiệt câu nhắc vào bộ mã hóa để tăng cường đặc trưng có chọn lọc; Cơ chế chú ý có điều kiện (Conditioned Attention) ràng buộc tín hiệu gating bằng câu nhắc tại từng tầng giải mã với trọng số giảm dần}}{43}{figure.3.5}%
\contentsline {figure}{\numberline {3.6}{\ignorespaces Pipeline phân lớp nhị phân MobileNetV4 Gatekeeper: resize và chuẩn hóa ảnh đầu vào, backbone MobileNetV4-Hybrid-Medium được tinh chỉnh hai giai đoạn (warmup đóng băng → full fine-tune), lớp phân lớp tuyến tính và Sigmoid với ngưỡng 0.5 quyết định CÓ/KHÔNG bệnh lý}}{50}{figure.3.6}%
\addvspace {10\p@ }
